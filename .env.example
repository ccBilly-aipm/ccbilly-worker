# ccBilly 工作台 · 环境变量示例
# 复制为 .env.local 后按需填写（.env* 已被 gitignore，不会提交）

# ── 鉴权模式（S1-4）───────────────────────────────────────────────
# none     = 默认。本机（localhost）单人使用，所有写操作免登录直接可用。
#            若从非本机地址访问，写操作会被「fail-closed」拒绝（提示配置鉴权）。
# passcode = 所有写操作（不只 /admin）都必须先登录后台会话。局域网/公网/Docker
#            部署时务必用此模式，并设置下方 ADMIN_PASSCODE。
AUTH_MODE=none

# 后台管理口令。
# - AUTH_MODE=none 时：仅防本机误触。
# - AUTH_MODE=passcode 时：这是真正的（单人）鉴权口令，请设置为强口令。
ADMIN_PASSCODE=changeme

# 可选：额外的项目级 Skill 扫描根目录（多个用英文逗号分隔）
# 个人级默认扫描 ~/.claude/skills/；此处配置项目级 <root>/.claude/skills/
CCBILLY_SKILL_PROJECT_ROOTS=

# 内部：E2E / 单测使用的隔离 vault 与 skills 目录（勿手动设置）
# CCBILLY_VAULT_DIR=
# CCBILLY_SKILLS_TEST_ROOT=
